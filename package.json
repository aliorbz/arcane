{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit",
    "contracts:compile": "hardhat compile --config hardhat.config.cjs",
    "contracts:deploy:arc": "hardhat run scripts/deploy.ts --network arcTestnet --config hardhat.config.cjs",
    "contracts:deploy-marketplace:arc": "set MARKETPLACE_ONLY=true&& set NFT_ADDRESS=0x92A6b7fafe0ea654f95938a9Ca744EB73598a285&& hardhat run scripts/deploy.ts --network arcTestnet --config hardhat.config.cjs",
    "contracts:check:arc": "hardhat run scripts/check-deploy.ts --network arcTestnet --config hardhat.config.cjs",
    "contracts:debug-accept": "hardhat run scripts/debug-accept-offer.ts --network arcTestnet --config hardhat.config.cjs",
    "contracts:debug-nfts": "hardhat run scripts/debug-nft-discovery.ts --network arcTestnet --config hardhat.config.cjs"
  },
  "dependencies": {
    "@google/genai": "^2.7.0",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.100.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "viem": "^2.51.2",
    "vite": "^6.2.3",
    "wagmi": "^3.6.16"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-verify": "^2.0.14",
    "@openzeppelin/contracts": "4.9.6",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "ethers": "^6.13.5",
    "hardhat": "^2.22.19",
    "tailwindcss": "^4.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
